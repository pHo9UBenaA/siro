{
  "name": "@pho9ubenaa/siro",
  "version": "0.1.4",
  "description": "Security best-practices linter for the npm ecosystem (npm, pnpm, deno, bun, yarn, aube).",
  "keywords": [
    "aube",
    "bun",
    "cli",
    "deno",
    "hardening",
    "lint",
    "linter",
    "npm",
    "pnpm",
    "security",
    "supply-chain",
    "yarn"
  ],
  "homepage": "https://github.com/pHo9UBenaA/siro#readme",
  "bugs": {
    "url": "https://github.com/pHo9UBenaA/siro/issues"
  },
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/pHo9UBenaA/siro.git"
  },
  "bin": {
    "siro": "./dist/cli.js"
  },
  "files": [
    "dist",
    "!dist/*.map",
    "README.md",
    "LICENSE",
    "CHANGELOG.md"
  ],
  "type": "module",
  "exports": {
    ".": {
      "types": "./dist/index.d.mts",
      "import": "./dist/index.mjs"
    }
  },
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "bench": "node ./scripts/bench/run.mjs",
    "build": "node ./scripts/gen/version.mjs && tsdown && node ./scripts/gen/bin-wrapper.mjs",
    "check": "oxlint --deny-warnings && oxfmt --check",
    "check:oss-coverage": "node ./oss-benchmarks/check.mjs",
    "format": "oxfmt --write",
    "gen": "pnpm gen:version && pnpm gen:comparison && pnpm gen:rules && pnpm gen:api",
    "gen:api": "typedoc",
    "gen:comparison": "node ./scripts/gen/comparison.mjs",
    "gen:rule": "node ./scripts/gen/rule.mjs",
    "gen:rules": "node ./scripts/gen/rules.mjs",
    "gen:version": "node ./scripts/gen/version.mjs",
    "knip": "knip",
    "prepublishOnly": "pnpm typecheck && pnpm test && pnpm build",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit && node ./scripts/check/layers.mjs"
  },
  "dependencies": {
    "cac": "catalog:",
    "ini": "catalog:",
    "jiti": "catalog:",
    "picocolors": "catalog:",
    "smol-toml": "catalog:",
    "valibot": "catalog:",
    "yaml": "catalog:"
  },
  "devDependencies": {
    "@commitlint/cli": "catalog:",
    "@commitlint/config-conventional": "catalog:",
    "@types/ini": "catalog:",
    "@types/node": "catalog:",
    "@vitest/coverage-v8": "catalog:",
    "knip": "catalog:",
    "memfs": "catalog:",
    "oxfmt": "catalog:",
    "oxlint": "catalog:",
    "tinybench": "catalog:",
    "tsdown": "catalog:",
    "typedoc": "catalog:",
    "typedoc-plugin-markdown": "catalog:",
    "typescript": "catalog:",
    "unrun": "catalog:",
    "vitest": "catalog:"
  },
  "engines": {
    "node": ">=20"
  },
  "packageManager": "pnpm@10.33.2",
  "pnpm": {
    "onlyBuiltDependencies": [
      "esbuild"
    ]
  }
}
